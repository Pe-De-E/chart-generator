# Backend Environment Variables

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://chartgen:dev_password@localhost:5432/chartgen_dev

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
ACCESS_TOKEN_SECRET=your-very-secure-access-token-secret-at-least-256-bits-long
REFRESH_TOKEN_SECRET=your-very-secure-refresh-token-secret-at-least-256-bits-long

# JWT Expiration
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15m
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=15m

# Bcrypt
BCRYPT_ROUNDS=12
