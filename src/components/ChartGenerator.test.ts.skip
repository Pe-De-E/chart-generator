import { describe, it, expect, beforeEach } from 'vitest'
import { mount, VueWrapper } from '@vue/test-utils'
import ChartGenerator from './ChartGenerator.vue'
import { createVuetify } from 'vuetify'
import * as components from 'vuetify/components'
import * as directives from 'vuetify/directives'

// Create Vuetify instance for tests
const vuetify = createVuetify({
  components,
  directives
})

describe('ChartGenerator.vue', () => {
  let wrapper: VueWrapper<any>

  beforeEach(() => {
    wrapper = mount(ChartGenerator, {
      global: {
        plugins: [vuetify]
      }
    })
  })

  it('should render the component', () => {
    expect(wrapper.exists()).toBe(true)
  })

  it('should start at step 1 (Upload)', () => {
    expect(wrapper.vm.currentStep).toBe(1)
  })

  it('should have default table items', () => {
    expect(wrapper.vm.tableItems.length).toBeGreaterThan(0)
    expect(wrapper.vm.tableItems[0]).toHaveProperty('col_0')
    expect(wrapper.vm.tableItems[0]).toHaveProperty('col_1')
  })

  it('should have default chart type as bar', () => {
    expect(wrapper.vm.chartType).toBe('bar')
  })

  it('should have default chart title', () => {
    expect(wrapper.vm.chartTitle).toBe('Mein Chart')
  })

  it('should have default colors', () => {
    expect(wrapper.vm.colors).toHaveProperty('primary')
    expect(wrapper.vm.colors).toHaveProperty('secondary')
    expect(wrapper.vm.colors).toHaveProperty('background')
  })

  it('should select col_0 as default label column', () => {
    expect(wrapper.vm.selectedLabelColumn).toBe('col_0')
  })

  it('should select col_1 as default value column', () => {
    expect(wrapper.vm.selectedValueColumn).toBe('col_1')
  })

  it('should generate column options from headers', () => {
    const options = wrapper.vm.columnOptions
    expect(options.length).toBeGreaterThan(0)
    expect(options[0]).toHaveProperty('title')
    expect(options[0]).toHaveProperty('value')
  })

  it('should generate numeric column options', () => {
    const options = wrapper.vm.numericColumnOptions
    expect(Array.isArray(options)).toBe(true)
  })

  it('should compute data from tableItems', () => {
    const data = wrapper.vm.data
    expect(Array.isArray(data)).toBe(true)
    expect(data.length).toBe(wrapper.vm.tableItems.length)
    if (data.length > 0) {
      expect(data[0]).toHaveProperty('label')
      expect(data[0]).toHaveProperty('value')
    }
  })

  it('should generate SVG content', () => {
    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<svg')
    expect(svg).toContain('</svg>')
  })

  it('should switch chart type when changed', async () => {
    wrapper.vm.chartType = 'line'
    await wrapper.vm.$nextTick()
    expect(wrapper.vm.chartType).toBe('line')

    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<svg')
  })

  it('should update SVG when chart title changes', async () => {
    const newTitle = 'New Chart Title'
    wrapper.vm.chartTitle = newTitle
    await wrapper.vm.$nextTick()

    const svg = wrapper.vm.svgContent
    expect(svg).toContain(newTitle)
  })

  it('should calculate data quality', () => {
    const quality = wrapper.vm.dataQuality
    expect(quality).toHaveProperty('totalRows')
    expect(quality).toHaveProperty('qualityScore')
    expect(quality).toHaveProperty('completenessPercentage')
  })

  it('should reset wizard to initial state', async () => {
    // Change some values
    wrapper.vm.chartTitle = 'Changed'
    wrapper.vm.chartType = 'pie'
    wrapper.vm.currentStep = 3

    // Reset
    wrapper.vm.resetWizard()
    await wrapper.vm.$nextTick()

    expect(wrapper.vm.currentStep).toBe(1)
    expect(wrapper.vm.chartTitle).toBe('Mein Chart')
    expect(wrapper.vm.chartType).toBe('bar')
  })

  it('should handle file upload', () => {
    // Create a mock CSV file
    const csvContent = 'Label,Value\nA,10\nB,20\nC,30'
    const file = new File([csvContent], 'test.csv', { type: 'text/csv' })

    // Trigger file upload
    wrapper.vm.handleFileUpload([file])

    // Wait for file reading to complete
    setTimeout(() => {
      expect(wrapper.vm.tableItems.length).toBeGreaterThan(0)
    }, 100)
  })

  it('should generate bar chart by default', () => {
    wrapper.vm.chartType = 'bar'
    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<rect') // Bar charts use rect elements
  })

  it('should generate line chart when selected', async () => {
    wrapper.vm.chartType = 'line'
    await wrapper.vm.$nextTick()
    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<polyline') // Line charts use polyline
  })

  it('should generate scatter chart when selected', async () => {
    wrapper.vm.chartType = 'scatter'
    await wrapper.vm.$nextTick()
    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<circle') // Scatter charts use circles
  })

  it('should generate pie chart when selected', async () => {
    wrapper.vm.chartType = 'pie'
    await wrapper.vm.$nextTick()
    const svg = wrapper.vm.svgContent
    expect(svg).toContain('<path') // Pie charts use path elements
  })

  it('should use custom colors in generated chart', async () => {
    wrapper.vm.colors.primary = '#FF0000'
    await wrapper.vm.$nextTick()

    const svg = wrapper.vm.svgContent
    expect(svg).toContain('#FF0000')
  })

  it('should have download SVG functionality', () => {
    expect(typeof wrapper.vm.downloadSVG).toBe('function')
  })
})

describe('ChartGenerator CSV parsing', () => {
  it('should parse CSV with comma delimiter', () => {
    const wrapper = mount(ChartGenerator, {
      global: {
        plugins: [vuetify]
      }
    })

    const csvContent = 'Name,Value\nProduct A,100\nProduct B,200'
    const file = new File([csvContent], 'test.csv', { type: 'text/csv' })

    wrapper.vm.handleFileUpload([file])

    setTimeout(() => {
      expect(wrapper.vm.tableItems.length).toBeGreaterThan(0)
    }, 100)
  })

  it('should parse CSV with semicolon delimiter', () => {
    const wrapper = mount(ChartGenerator, {
      global: {
        plugins: [vuetify]
      }
    })

    const csvContent = 'Name;Value\nProduct A;100\nProduct B;200'
    const file = new File([csvContent], 'test.csv', { type: 'text/csv' })

    wrapper.vm.handleFileUpload([file])

    setTimeout(() => {
      expect(wrapper.vm.tableItems.length).toBeGreaterThan(0)
    }, 100)
  })

  it('should handle CSV with decimal comma', () => {
    const wrapper = mount(ChartGenerator, {
      global: {
        plugins: [vuetify]
      }
    })

    const csvContent = 'Name,Value\nA,10,5\nB,20,3'
    const file = new File([csvContent], 'test.csv', { type: 'text/csv' })

    wrapper.vm.handleFileUpload([file])

    setTimeout(() => {
      // Should parse 10,5 as 10.5
      expect(wrapper.vm.tableItems.length).toBeGreaterThan(0)
    }, 100)
  })
})
