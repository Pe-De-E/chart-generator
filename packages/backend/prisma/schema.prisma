// Prisma schema for chart generator backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  emailVerified Boolean   @default(false) @map("email_verified")
  isAdmin       Boolean   @default(false) @map("is_admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  refreshTokens   RefreshToken[]
  charts          Chart[]
  payments        Payment[]
  tickets         Ticket[]
  chartPresets    ChartPreset[]    @relation("UserChartPresets")
  elevationThemes ElevationTheme[] @relation("UserElevationThemes")
  images          UserImage[]      @relation("UserImages")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Future feature: Chart persistence
model Chart {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  type       String   // 'bar', 'line', 'scatter', 'pie', 'area'
  data       Json     // Chart data
  config     Json     // Chart configuration
  svgContent String?  @db.Text @map("svg_content")
  isPublic   Boolean  @default(false) @map("is_public")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@map("charts")
}

// Request logging for admin dashboard
model RequestLog {
  id           String   @id @default(uuid())
  method       String
  path         String
  statusCode   Int      @map("status_code")
  userId       String?  @map("user_id")
  userEmail    String?  @map("user_email")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  responseTime Int      @map("response_time")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([statusCode])
  @@map("request_logs")
}

// Error logging for admin dashboard
model ErrorLog {
  id           String    @id @default(uuid())
  errorCode    String    @map("error_code")
  errorMessage String    @db.Text @map("error_message")
  stackTrace   String?   @db.Text @map("stack_trace")
  userId       String?   @map("user_id")
  userEmail    String?   @map("user_email")
  path         String?
  method       String?
  severity     String    @default("error")
  resolved     Boolean   @default(false)
  resolvedAt   DateTime? @map("resolved_at")
  resolvedBy   String?   @map("resolved_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([severity])
  @@index([resolved])
  @@map("error_logs")
}

// Payment table (prepared for Stripe/PayPal integration)
model Payment {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("EUR")
  status             PaymentStatus @default(PENDING)
  provider           String?
  providerPaymentId  String?       @map("provider_payment_id")
  providerCustomerId String?       @map("provider_customer_id")
  description        String?
  failureReason      String?       @map("failure_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  completedAt        DateTime?     @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// Ticket/Feedback system
enum TicketType {
  BUG
  FEATURE
  QUESTION
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Ticket {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  subject     String
  message     String       @db.Text
  type        TicketType   @default(QUESTION)
  status      TicketStatus @default(OPEN)
  adminNotes  String?      @db.Text @map("admin_notes")
  resolvedAt  DateTime?    @map("resolved_at")
  resolvedBy  String?      @map("resolved_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

// Chart Styling Presets (for Bar, Line, Scatter, Pie, Area Charts)
model ChartPreset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  config    Json     // ChartPresetConfig
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation("UserChartPresets", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chart_presets")
}

// Elevation Chart Themes
model ElevationTheme {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  preview     String   // CSS gradient/color for preview swatch
  tokens      Json     // ElevationThemeTokens
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation("UserElevationThemes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("elevation_themes")
}

// User uploaded images (for chart backgrounds)
model UserImage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  filename  String   // Original filename
  mimetype  String   // image/jpeg, image/png, image/webp
  size      Int      // File size in bytes
  path      String   // Server path: /uploads/images/{userId}/{id}.ext
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserImages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_images")
}
